				DiffuseColor  += Weight * (SubstrateEnvLight.DiffuseWeight + SubstrateEnvLight.DiffuseBackFaceWeight); 
				SpecularColor += Weight * SubstrateEnvLight.SpecularWeight;
				SpecularColor += Weight * SubstrateEnvLight.SpecularHazeWeight;
				WorldNormal   += Weight * SubstrateBSDFContext.N;
				Emissive      += Weight * SubstratePixelHeader.SubstrateTree.BSDFs[BSDFIdx].Emissive;



