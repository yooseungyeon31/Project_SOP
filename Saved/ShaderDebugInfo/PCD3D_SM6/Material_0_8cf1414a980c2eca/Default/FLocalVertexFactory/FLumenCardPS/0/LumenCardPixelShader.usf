#line 100 "/Engine/Private/Substrate/SubstrateLegacyConversion.ush"
FSubstrateData CreateLegacySlab(
	FSubstrateLegacyParameters In, inout uint SharedLocalBasisTypes)
{
	const float3 Zeros = float3(0, 0, 0);
	const float3 Ones  = float3(1, 1, 1);

	float3 DiffuseAlbedo = In.DiffuseAlbedo;
	float3 F0 = In.F0;
	float3 F90 = In.F90;
	if (In.UseMetalness)
	{
		DiffuseAlbedo = ComputeDiffuseAlbedo(In.BaseColor, In.Metallic);
		F0 = ComputeF0(In.Specular, In.BaseColor, In.Metallic);
		F90 = Ones;
	}


	return GetSubstrateSlabBSDF(
		In.PixelFootprint,
		In.RawNormal,										
		DiffuseAlbedo,										
		F0,													
		F90,												
		In.Roughness,										
		In.Anisotropy,										
		In.SSSProfileID,									
		In.bSupportDefaultSSSProfile,						
		In.SSSMFP,											
		In.SSSMFPScale,										
		In.SSSPhaseAniso,									
		In.SSSType,											
		In.Emissive,										
		In.SecondRoughness,									
		In.SecondRoughnessWeight,							
		In.SecondRoughnessAsSimpleClearCoat ? 1.0f : 0.0f,	
		In.ClearCoatUseBottomNormal ? 1.0f : 0.0f,			
		In.ClearCoatBottomNormal,							
		In.FuzzAmount,										
		In.FuzzColor,										
		0.5 + 0.5 * In.Roughness,							
		1.0f, (float2)0,								
		0.0f,												
		In.Thickness,
		In.bIsThinSurface,
		true,												
		In.SharedLocalBasisIndex, SharedLocalBasisTypes);
}

