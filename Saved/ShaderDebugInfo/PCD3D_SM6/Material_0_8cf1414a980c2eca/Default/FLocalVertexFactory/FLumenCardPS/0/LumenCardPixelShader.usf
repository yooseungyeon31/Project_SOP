uint PackR8(float Value)
{
	return uint(saturate(Value) * 255.0f);
}

#line 102 "/Engine/Private/PackUnpack.ush"
float UnpackR8(uint In)
{



	return float(BitFieldExtractU32(In, 8, 0)) * (1.0f / 255.0f);

