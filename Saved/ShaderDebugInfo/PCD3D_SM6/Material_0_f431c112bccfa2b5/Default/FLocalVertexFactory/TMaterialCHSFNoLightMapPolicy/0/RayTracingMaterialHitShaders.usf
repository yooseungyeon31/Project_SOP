	{
	case 0:
	{
		if (  uint(( BSDF .State >>( ((0			+ 1)			+ 1) )) &  ((1u<<( 3 ))-1)) != (0u))
		{
			const float3 Extinction = 1.0f / max(1e-10f,   BSDF .VGPRs[3].xyz * (1.0f / 100.0f));
			return ExtinctionToTransmittance(Extinction, 100.0f * (1.0f / 100.0f));
