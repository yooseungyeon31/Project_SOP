		else if (  uint(( BSDF .State >>( (((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1) )) &  ((1u<<( 1 ))-1)))
		{
			return   BSDF .VGPRs[4].xyz; 
