{
	if (  uint(( this .State >>( ((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1) )) &  ((1u<<( 1 ))-1)))
	{
		if (!this.bIsBottom ||   uint(( this .State >>( ((0			+ 1)			+ 1) )) &  ((1u<<( 3 ))-1)) == (5u))
