	{
	case 0: 				return lerp(  BSDF .VGPRs[0].xyz,   BSDF .VGPRs[1].xyz, F0RGBToMetallic(  BSDF .VGPRs[1].xyz));  
	case 3: 				return   BSDF .VGPRs[0].xyz;
	case 5: 				return   BSDF .VGPRs[0].xyz;
